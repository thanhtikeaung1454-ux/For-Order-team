<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inventory Management App</title>
    <style>
        * { box-sizing: border-box; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        body { background-color: #121212; color: #e0e0e0; margin: 0; padding: 15px; }
        h2 { color: #4CAF50; font-size: 16pt; margin-top: 10px; margin-bottom: 15px; border-left: 4px solid #4CAF50; padding-left: 8px; }
        .form-container { background-color: #1e1e1e; padding: 15px; border-radius: 8px; border: 1px solid #333; margin-bottom: 20px; }
        .form-group { margin-bottom: 12px; }
        label { display: block; font-size: 10pt; color: #aaa; margin-bottom: 5px; }
        input[type="date"], input[type="text"], input[type="number"] { 
            width: 100%; padding: 10px; background-color: #2a2a2a; border: 1px solid #444; 
            border-radius: 4px; color: #fff; font-size: 11pt;
        }
        input:focus { border-color: #4CAF50; outline: none; }
        button { 
            width: 100%; padding: 12px; background-color: #4CAF50; border: none; 
            border-radius: 4px; color: white; font-size: 12pt; font-weight: bold; cursor: pointer;
            margin-top: 10px;
        }
        button:active { background-color: #45a049; }
        .table-container { background-color: #1e1e1e; border-radius: 8px; border: 1px solid #333; overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; min-width: 500px; }
        th, td { padding: 12px 10px; text-align: left; font-size: 10.5pt; border-bottom: 1px solid #333; }
        th { background-color: #252525; color: #4CAF50; font-weight: 600; }
        tr:nth-child(even) { background-color: #161616; }
        .total-row { background-color: #252525 !important; font-weight: bold; color: #fff; border-top: 2px solid #4CAF50; }
        .total-row td { color: #4CAF50; }
        .delete-btn { background-color: #ff5252; color: white; border: none; padding: 5px 8px; border-radius: 4px; cursor: pointer; font-size: 9pt; }
        .clear-all-btn { background-color: #333; color: #ff5252; border: 1px solid #444; margin-top: 15px; padding: 10px; font-size: 10pt; width: 100%; }
    </style>
</head>
<body>
    <h2>📝 ကုန်ပစ္စည်းစာရင်းသွင်းရန်</h2>
    <div class="form-container">
        <form id="inventoryForm">
            <div class="form-group">
                <label>နေ့စွဲ (Date)</label>
                <input type="date" id="date" required>
            </div>
            <div class="form-group">
                <label>ဝယ်သူအမည် (Customer)</label>
                <input type="text" id="customer" placeholder="အမည်ရိုက်ထည့်ပါ" required>
            </div>
            <div class="form-group">
                <label>ဂျပ်စုစုပေါင်း</label>
                <input type="number" id="cardboard" placeholder="အရေအတွက်" min="0" required>
            </div>
            <div class="form-group">
                <label>ပီနံစုစုပေါင်း</label>
                <input type="number" id="feedBag" placeholder="အရေအတွက်" min="0" required>
            </div>
            <div class="form-group">
                <label>မှတ်ချက် (Note)</label>
                <input type="text" id="note" placeholder="မှတ်ချက်ရှိက ရေးရန်">
            </div>
            <button type="submit">💾 စာရင်းသိမ်းဆည်းမည်</button>
        </form>
    </div>

    <h2>📊 အရောင်းစာရင်းဇယား (ပွတ်ကြည့်နိုင်သည်)</h2>
    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Customer</th>
                    <th>ဂျပ်</th>
                    <th>ပီနံ</th>
                    <th>Total</th>
                    <th>Note</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody id="tableBody"></tbody>
            <tfoot>
                <tr class="total-row">
                    <td colspan="2">စုစုပေါင်း (Total)</td>
                    <td id="totalCardboard">0</td>
                    <td id="totalFeedBag">0</td>
                    <td id="grandTotal">0</td>
                    <td></td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    </div>
    <button class="clear-all-btn" onclick="clearAllData()">⚠️ ဒေတာအားလုံးကို ဖျက်ပစ်မည်</button>

    <script>
        document.getElementById('date').valueAsDate = new Date();
        let records = JSON.parse(localStorage.getItem('inventory_records')) || [];
        updateTable();

        document.getElementById('inventoryForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const date = document.getElementById('date').value;
            const customer = document.getElementById('customer').value;
            const cardboard = parseInt(document.getElementById('cardboard').value) || 0;
            const feedBag = parseInt(document.getElementById('feedBag').value) || 0;
            const note = document.getElementById('note').value;
            const total = cardboard + feedBag;

            records.push({ id: Date.now(), date, customer, cardboard, feedBag, total, note });
            saveToLocalStorage();
            updateTable();
            
            document.getElementById('customer').value = '';
            document.getElementById('cardboard').value = '';
            document.getElementById('feedBag').value = '';
            document.getElementById('note').value = '';
            document.getElementById('date').valueAsDate = new Date();
        });

        function updateTable() {
            const tbody = document.getElementById('tableBody');
            tbody.innerHTML = '';
            let totalC = 0, totalF = 0, grandT = 0;

            records.forEach(r => {
                totalC += r.cardboard;
                totalF += r.feedBag;
                grandT += r.total;
                tbody.innerHTML += `
                    <tr>
                        <td>${r.date}</td>
                        <td>${r.customer}</td>
                        <td>${r.cardboard}</td>
                        <td>${r.feedBag}</td>
                        <td>${r.total}</td>
                        <td>${r.note || '-'}</td>
                        <td><button class="delete-btn" onclick="deleteRecord(${r.id})">ဖျက်ရန်</button></td>
                    </tr>
                `;
            });
            document.getElementById('totalCardboard').innerText = totalC;
            document.getElementById('totalFeedBag').innerText = totalF;
            document.getElementById('grandTotal').innerText = grandT;
        }

        function deleteRecord(id) {
            if(confirm("ဤစာရင်းကို ဖျက်ရန် သေချာပါသလား?")) {
                records = records.filter(r => r.id !== id);
                saveToLocalStorage();
                updateTable();
            }
        }

        function clearAllData() {
            if(confirm("သတိပေးချက်: စာရင်းဒေတာအားလုံး ပျက်သွားပါလိမ့်မည်။ သေချာပါသလား?")) {
                records = [];
                saveToLocalStorage();
                updateTable();
            }
        }

        function saveToLocalStorage() {
            localStorage.setItem('inventory_records', JSON.stringify(records));
        }
    </script>
</body>
</html>
